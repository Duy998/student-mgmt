# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=student_db
DATABASE_URL=postgresql://postgres:postgres@db:5432/student_db

# JWT — generate a strong key: openssl rand -hex 32
SECRET_KEY=replace-this-with-a-strong-random-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS — comma separated origins allowed to call the API
ALLOWED_ORIGINS=http://localhost,http://localhost:80,http://127.0.0.1
